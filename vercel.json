{
  "rewrites": [
    { "source": "/whoop/callback", "destination": "/api/whoop/callback" },
    { "source": "/whoop/login",    "destination": "/api/whoop/login"    }
  ],
  "headers": [
    {
      "source": "/(.*)\\.html",
      "headers": [
        { "key": "Cache-Control", "value": "no-store, must-revalidate" }
      ]
    },
    {
      "source": "/(db|cloud-sync|theme)\\.js",
      "headers": [
        { "key": "Cache-Control", "value": "no-store, must-revalidate" }
      ]
    }
  ]
}
